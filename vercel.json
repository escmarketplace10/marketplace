{
  "version": 2,
  "builds": [
    {
      "src": "admin/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/src/index.ts"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/admin/assets/$1"
    },
    {
      "source": "/(sw.js|manifest.webmanifest|icon.svg|favicon.svg|icons.svg)",
      "destination": "/admin/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/admin/index.html"
    }
  ]
}
