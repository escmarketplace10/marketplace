{
  "version": 2,
  "builds": [
    {
      "src": "admin/package.json",
      "use": "@vercel/vite"
    },
    {
      "src": "backend/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/src/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/admin/dist/$1"
    }
  ]
}
